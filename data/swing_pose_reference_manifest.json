{
  "version": 1,
  "purpose": "Step 1 intake list for Swing pose references. These are visual targets before numeric pose values are authored.",
  "referenceRoot": "assets/reference/swing-poses",
  "globalRules": {
    "leftArm": "When hooked, left hand/wrist is the grapple hand and must stay aligned to the rope direction.",
    "bodyParts": "Body parts remain rigid. No stretching.",
    "legs": "Legs react to swing momentum and direction, not random bend.",
    "ribbon": "Ribbon is anchored to the back of the head and trails motion.",
    "poseStorage": "Later steps convert approved references into numeric joint rotations and blend rules."
  },
  "poses": [
    {
      "key": "idle_hang",
      "label": "Idle hang",
      "file": "",
      "status": "needs_reference",
      "priority": 3,
      "motion": "stationary or near stationary",
      "mustShow": [
        "relaxed upright silhouette",
        "arms not stiff",
        "knees slightly natural",
        "ribbon resting or lightly trailing"
      ],
      "notes": ""
    },
    {
      "key": "hook_firing",
      "label": "Hook firing",
      "file": "",
      "status": "needs_reference",
      "priority": 3,
      "motion": "pre-catch, grapple being fired",
      "mustShow": [
        "left arm reaching toward rope direction",
        "right arm balancing",
        "body preparing for tension"
      ],
      "notes": ""
    },
    {
      "key": "hook_catch",
      "label": "Hook catch",
      "file": "",
      "status": "needs_reference",
      "priority": 1,
      "motion": "first moment rope takes weight",
      "mustShow": [
        "left wrist on rope line",
        "left shoulder pulled by rope",
        "body compressing under catch",
        "legs reacting to sudden tension"
      ],
      "notes": ""
    },
    {
      "key": "down_swing",
      "label": "Down swing",
