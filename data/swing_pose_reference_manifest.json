      "status": "needs_reference",
      "priority": 1,
      "motion": "falling along rope arc",
      "mustShow": [
        "left arm aligned to rope",
        "torso pulled under anchor",
        "legs trailing behind velocity",
        "right arm used for balance"
      ],
      "notes": ""
    },
    {
      "key": "bottom_swing",
      "label": "Bottom of swing",
      "file": "",
      "status": "needs_reference",
      "priority": 1,
      "motion": "fastest point of swing",
      "mustShow": [
        "strong rope tension",
        "left arm extended on rope line",
        "legs pushed forward by momentum",
        "torso arced through swing"
      ],
      "notes": ""
    },
    {
      "key": "up_swing",
      "label": "Up swing",
      "file": "",
      "status": "needs_reference",
      "priority": 1,
      "motion": "rising after bottom arc",
      "mustShow": [
        "body elongated by upward momentum",
